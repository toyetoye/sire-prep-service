# SIRE Prep Service — environment variables
# Copy this to .env locally; on Railway, set these via the Variables tab.

# PostgreSQL — point to MARIDE's existing Railway DB.
# Railway gives you DATABASE_URL automatically if you link the Postgres add-on,
# or you can grab the public connection string from the Postgres dashboard.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/railway

# Session signing secret — generate any 32+ char random string.
# On Railway: openssl rand -hex 32, paste result here.
SESSION_SECRET=replace-me-with-32-char-random-hex

# Port — Railway sets this automatically. Locally use 3000.
PORT=3000

# Initial vessel passwords used only by the seed script. Run once, then change in DB.
SEED_AT_PASSWORD=at-sire-change-me
SEED_AT10_PASSWORD=at10-sire-change-me

# Bootstrap superintendent account (set these to create the first super on seed).
# Once created, all other users can be added through the Admin tab in the app.
# Seed will skip these if a user with the same email already exists.
SEED_ADMIN_EMAIL=omolade@nsml.com
SEED_ADMIN_PASSWORD=change-me-strong-8-plus-chars
SEED_ADMIN_NAME=Omolade Akinmoladun
